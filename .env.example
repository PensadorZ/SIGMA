# =============================================================================
# .env.example — Variables de entorno SIGMA Hito 1
# SIGMA v1.7
# Autor: Prof. Marx Agustín García Delgado
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena cada valor con tus credenciales reales
#   3. NUNCA subas .env a Git (está en .gitignore)
#   4. Este archivo (.env.example) SÍ va a Git — es la plantilla pública
#
# NOTA v2.0.0 — RECONCILIADO con el .env real. Los nombres aquí son los que
# el código realmente lee en primer lugar; los nombres antiguos siguen
# funcionando como alias de compatibilidad en el código (_common.py,
# zulip_notifier.py, skill.py de 0000 y 0011) pero ya no son la forma canónica.
#
# ADR-010: Gestión de Secretos — Principio de Inyección Cero
# Ninguna credencial debe aparecer en el código fuente ni en SKILL.md.
# Todas las credenciales se obtienen con get_required_env() en tiempo
# de ejecución. Si falta alguna, el sistema falla rápido con mensaje claro.
#
# -----------------------------------------------------------------------------
# English version
# -----------------------------------------------------------------------------
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in each value with your real credentials
#   3. NEVER commit .env to Git (it's in .gitignore)
#   4. This file (.env.example) DOES go to Git — it's the public template
#
# NOTE v2.0.0 — RECONCILED with the real .env. The names here are what the
# code actually reads first; the old names still work as compatibility
# aliases in the code (_common.py, zulip_notifier.py, skill.py for 0000 and
# 0011) but are no longer the canonical form.
#
# ADR-010: Secrets Management — Zero-Injection Principle
# No credential should ever appear in source code or in SKILL.md. All
# credentials are obtained via get_required_env() at runtime. If one is
# missing, the system fails fast with a clear message.
# =============================================================================

# -----------------------------------------------------------------------------
# SIGMA — Configuración general/General configuration
# -----------------------------------------------------------------------------

# Variante activa: Full | Lite | Dev | Runtime
# Active variant: Full | Lite | Dev | Runtime
SIGMA_VARIANT=Full

# Dispositivo de inferencia para RoBERTa: cpu | cuda
# Inference device for RoBERTa: cpu | cuda
SIGMA_DEVICE=cpu

# Tamaño de batch para inferencia RoBERTa
# Batch size for RoBERTa inference
SIGMA_BATCH_SIZE=32

# Umbral de confianza para clasificación de sentimiento (K ⊆ X — ADR-008)
# Confidence threshold for sentiment classification (K ⊆ X — ADR-008)
SIGMA_CONFIDENCE_THRESHOLD=0.65

# Provider del resumen textual en viz-reporter: ollama | gemini | none
# Text-summary provider in viz-reporter: ollama | gemini | none
SIGMA_SUMMARY_PROVIDER=ollama

# -----------------------------------------------------------------------------
# Entorno de ejecución — variables reservadas
# NOTA: estas variables existen en la configuración del sistema, pero
# todavía no están conectadas a ningún skill.py — quedan reservadas
# para cuando se implemente su consumo real.
# -----------------------------------------------------------------------------
# English version
# -----------------------------------------------------------------------------
# Execution environment — reserved variables
# NOTE: these variables exist in the system's configuration, but
# aren't wired to any skill.py yet — they're reserved for when their
# real consumption is implemented.
# -----------------------------------------------------------------------------
EXECUTION_ENVIRONMENT=local
EXECUTION_MODE=BUILD
MAX_BUDGET_USD=5.0

# NOTA: Puertos no estándar (5433, 6380, 9002, 3001) — se usan
# desplazados del estándar (5432, 6379, 9000, 3000) para poder correr
# en paralelo con otros proyectos locales en la misma máquina sin
# colisión de puertos.
# -----------------------------------------------------------------------------
# Base de datos — PostgreSQL
# DATABASE_URL es el nombre canónico real. Alias de compatibilidad:
# POSTGRES_DSN, o los campos separados POSTGRES_HOST/PORT/DB/USER/PASSWORD.
# -----------------------------------------------------------------------------
# English version
# -----------------------------------------------------------------------------
# NOTE: Non-standard ports (5433, 6380, 9002, 3001) — offset from the
# standard ones (5432, 6379, 9000, 3000) so this can run in parallel
# with other local projects on the same machine without port collisions.
# -----------------------------------------------------------------------------
# Database — PostgreSQL
# DATABASE_URL is the real canonical name. Compatibility aliases:
# POSTGRES_DSN, or the separate fields POSTGRES_HOST/PORT/DB/USER/PASSWORD.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://usuario:password@localhost:5433/sigma

# Campos separados — solo se usan si DATABASE_URL no está definida
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=sigma
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password_aqui

# -----------------------------------------------------------------------------
# Redis
# REDIS_URL es el nombre canónico real. Alias: REDIS_HOST/PORT/PASSWORD/DB.
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Redis
# REDIS_URL is the real canonical name. Alias: REDIS_HOST/PORT/PASSWORD/DB.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6380
# Sin credenciales en local — completar solo si la instancia lo requiere
# REDIS_PASSWORD=solo_si_la_instancia_lo_requiere
# -----------------------------------------------------------------------------
# English version:
# No credentials needed locally — fill in only if the instance requires them
# REDIS_PASSWORD=only_if_the_instance_requires_it

# -----------------------------------------------------------------------------
# MinIO (almacenamiento de objetos S3-compatible)
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=tu_access_key_aqui
MINIO_SECRET_KEY=tu_secret_key_aqui
MINIO_BUCKET_DASHBOARDS=dashboards
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Modelo RoBERTa — cardiffnlp/twitter-roberta-base-sentiment-latest
# -----------------------------------------------------------------------------
ROBERTA_MODEL_PATH=./models/twitter-roberta-base-sentiment-latest

# -----------------------------------------------------------------------------
# Ollama — modelos locales
# OLLAMA_BASE_URL es el nombre canónico real. Alias: OLLAMA_HOST.
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SUMMARY_MODEL=llama3.2:3b

# -----------------------------------------------------------------------------
# Gemini API — orquestador (solo si SIGMA_SUMMARY_PROVIDER=gemini o para
# análisis de errores desconocidos en el circuit breaker)
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Gemini API — orchestrator (only if SIGMA_SUMMARY_PROVIDER=gemini, or for
# analyzing unknown errors in the circuit breaker)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=tu_gemini_api_key_aqui
GEMINI_SUMMARY_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# Langfuse — observabilidad y trazabilidad
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Langfuse — observability and traceability
# -----------------------------------------------------------------------------
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-tu_public_key_aqui
LANGFUSE_SECRET_KEY=sk-lf-tu_secret_key_aqui

# -----------------------------------------------------------------------------
# Zulip — notificaciones HITL
# Nombres canónicos reales: ZULIP_EMAIL, ZULIP_API_KEY, ZULIP_ORGANIZATION_URL.
# Alias de compatibilidad: ZULIP_BOT_EMAIL, ZULIP_BOT_API_KEY, ZULIP_SITE.
#
# Dos topics separados — permite silenciar notificaciones de ejecución
# sin perder las preguntas HITL que sí requieren respuesta:
#   ZULIP_TOPIC_RUNS → eventos de inicio/éxito/error del pipeline
#   ZULIP_TOPIC_HITL → preguntas que requieren confirmación
# -----------------------------------------------------------------------------
# English version
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Zulip — HITL notifications
# Real canonical names: ZULIP_EMAIL, ZULIP_API_KEY, ZULIP_ORGANIZATION_URL.
# Compatibility aliases: ZULIP_BOT_EMAIL, ZULIP_BOT_API_KEY, ZULIP_SITE.
#
# Two separate topics — lets you silence execution notifications without
# missing the HITL questions that do require a response:
#   ZULIP_TOPIC_RUNS → pipeline start/success/error events
#   ZULIP_TOPIC_HITL → questions requiring confirmation
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Zulip — notificaciones HITL
# ADVERTENCIA: nunca declares ZULIP_BOT_EMAIL/ZULIP_BOT_API_KEY dos veces
# en este archivo. Un .env no genera error de sintaxis con claves
# duplicadas — la segunda declaración sobrescribe la primera en
# silencio (ver TROUBLESHOOTING.md, Incidente 6).
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Zulip — HITL notifications
# WARNING: never declare ZULIP_BOT_EMAIL/ZULIP_BOT_API_KEY twice in
# this file. A .env produces no syntax error from duplicated keys —
# the second declaration silently overwrites the first (see
# TROUBLESHOOTING.md, Incident 6).
# -----------------------------------------------------------------------------

ZULIP_EMAIL=programador-bot@tu-organizacion.zulipchat.com
ZULIP_API_KEY=tu_zulip_api_key_aqui
ZULIP_ORGANIZATION_URL=tu-organizacion.zulipchat.com
ZULIP_STREAM=sigma-hito1
ZULIP_TOPIC_RUNS=pipeline-runs
ZULIP_TOPIC_HITL=hitl-confirmaciones

# -----------------------------------------------------------------------------
# Kaggle — descarga de datasets (token formato KGAT, no kaggle.json clásico)
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Kaggle — dataset download (KGAT token format, not the classic kaggle.json)
# -----------------------------------------------------------------------------
KAGGLE_USERNAME=tu_usuario_kaggle
KAGGLE_KEY=tu_kaggle_api_token_aqui

# -----------------------------------------------------------------------------
# Netlify — despliegue opcional de dashboards (Hito 2+, no necesario en Hito 1)
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Netlify — optional dashboard deployment (Milestone 2+, not needed for Milestone 1)
# -----------------------------------------------------------------------------
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=tu_token_auth_key_aqui
NETLIFY_SITE_ID=tu_site_id_aqui
